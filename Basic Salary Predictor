from sklearn.linear_model import LinearRegression
import numpy as np

training_experience = [[1], [2], [3], [4], [5]]
training_data = [4, 5, 6, 7, 8]

linear_regression_model = LinearRegression()
linear_regression_model.fit(training_experience, training_data)

experience = float(input("Enter the years of experience: "))

salary_prediction = linear_regression_model.predict([[experience]])

print(f"Predicted salary: ${salary_prediction[0]}")
